{
  "entities": {
    "Chat": {
      "title": "Chat Session",
      "description": "A chat session containing multiple messages.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this chat."
        },
        "title": {
          "type": "string",
          "description": "The title of the chat session."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the chat was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the chat was last updated."
        }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "Message": {
      "title": "Chat Message",
      "description": "A single message within a chat session.",
      "type": "object",
      "properties": {
        "chatId": {
          "type": "string",
          "description": "The ID of the parent chat session."
        },
        "role": {
          "type": "string",
          "enum": ["user", "model"],
          "description": "The role of the message sender."
        },
        "content": {
          "type": "string",
          "description": "The text content of the message."
        },
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "List of base64 encoded images."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the message was sent."
        }
      },
      "required": ["chatId", "role", "content", "createdAt"]
    },
    "Script": {
      "title": "Saved Script",
      "description": "A Luau script saved by the user.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who owns this script."
        },
        "name": {
          "type": "string",
          "description": "The name of the script."
        },
        "content": {
          "type": "string",
          "description": "The Luau code content."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the script was saved."
        }
      },
      "required": ["userId", "name", "content", "createdAt"]
    },
    "User": {
      "title": "Application User",
      "description": "User profile and activity tracking.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" },
        "isOnline": { "type": "boolean" },
        "lastIp": { "type": "string", "description": "The last known IP address of the user." },
        "isBanned": { "type": "boolean" },
        "bannedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "lastActive"]
    },
    "BannedIP": {
      "title": "Banned IP Address",
      "description": "An IP address that is blocked from accessing the app.",
      "type": "object",
      "properties": {
        "ip": { "type": "string" },
        "reason": { "type": "string" },
        "bannedAt": { "type": "string", "format": "date-time" },
        "bannedBy": { "type": "string", "description": "UID of the admin who banned this IP." }
      },
      "required": ["ip", "bannedAt"]
    },
    "Config": {
      "title": "App Configuration",
      "description": "Global settings and API keys.",
      "type": "object",
      "properties": {
        "geminiApiKeys": { "type": "array", "items": { "type": "string" } },
        "groqApiKey": { "type": "string" },
        "maintenanceMode": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "AccessLog": {
      "title": "Access Log",
      "description": "Recording of user access events.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "ip": { "type": "string" },
        "email": { "type": "string" },
        "fingerprint": { "type": "object" },
        "suspicious": { "type": "boolean" }
      },
      "required": ["uid", "timestamp"]
    },
    "SecurityAlert": {
      "title": "Security Alert",
      "description": "Alert triggered by suspicious activity.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "severity": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "details": { "type": "string" },
        "userId": { "type": "string" },
        "ip": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "severity", "createdAt"]
    },
    "ErrorLog": {
      "title": "Error Log",
      "description": "Recording of application errors.",
      "type": "object",
      "properties": {
        "error": { "type": "string" },
        "code": { "type": "string" },
        "location": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["error", "createdAt"]
    },
    "UserStats": {
      "title": "User Stats",
      "description": "Tracks export limits and cooldowns.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "dailyExportCount": { "type": "integer" },
        "lastExportDate": { "type": "string" },
        "nextExportAllowedAt": { "type": "string", "format": "date-time" },
        "lastMessagesCount": { "type": "integer" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "/user_stats/{userId}": {
      "schema": "UserStats",
      "description": "User limits for exports."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Collection of chat sessions."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Sub-collection of messages for a specific chat."
    },
    "/scripts/{scriptId}": {
      "schema": "Script",
      "description": "Collection of saved Luau scripts."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and activity."
    },
    "/banned_ips/{ip}": {
      "schema": "BannedIP",
      "description": "List of banned IP addresses."
    },
    "/config/{configId}": {
      "schema": "Config",
      "description": "Global configuration."
    },
    "/access_logs/{logId}": {
      "schema": "AccessLog",
      "description": "Logs of user access events."
    },
    "/security_alerts/{alertId}": {
      "schema": "SecurityAlert",
      "description": "Security signals recorded."
    },
    "/error_logs/{logId}": {
      "schema": "ErrorLog",
      "description": "Application errors recorded."
    },
    "/admins/{userId}": {
      "schema": { "type": "object", "properties": { "email": { "type": "string" } } },
      "description": "Administrator accounts."
    }
  }
}
