// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: chats
// Document ID: {chatId}
// Fields:
//   - userId: string (required) - Owner UID
//   - title: string (required) - Chat title
//   - createdAt: timestamp (required)
//   - updatedAt: timestamp (required)
//
// Collection: chats/{chatId}/messages
// Document ID: {messageId}
// Fields:
//   - chatId: string (required)
//   - role: string (required, enum: ['user', 'model'])
//   - content: string (required)
//   - createdAt: timestamp (required)
//
// Collection: scripts
// Document ID: {scriptId}
// Fields:
//   - userId: string (required)
//   - name: string (required)
//   - content: string (required)
//   - createdAt: timestamp (required)
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - uid: string (required)
//   - email: string
//   - displayName: string
//   - photoURL: string
//   - lastActive: timestamp (required)
//   - isOnline: boolean
//
// Collection: config
// Document ID: main
// Fields:
//   - geminiApiKeys: list (strings)
//   - updatedAt: timestamp
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "wesley04012011w@gmail.com" || 
              request.auth.token.email == "soparonosk37@gmail.com");
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isChatOwner(chatId) {
      return isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)).data.userId;
    }

    function isValidChat(data) {
      return data.keys().hasAll(['userId', 'title', 'createdAt', 'updatedAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'role', 'content', 'createdAt']) &&
             data.role in ['user', 'model'] &&
             data.content is string && data.content.size() <= 100000 &&
             (!('images' in data) || (data.images is list && data.images.size() <= 10)) &&
             data.createdAt is timestamp;
    }

    function isValidScript(data) {
      return data.keys().hasAll(['userId', 'name', 'content', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.content is string && data.content.size() <= 100000 &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'lastActive']) &&
             data.uid == request.auth.uid &&
             data.lastActive is timestamp &&
             (!('email' in data) || data.email == null || data.email is string) &&
             (!('displayName' in data) || data.displayName == null || data.displayName is string) &&
             (!('photoURL' in data) || data.photoURL == null || data.photoURL is string) &&
             (!('isOnline' in data) || data.isOnline == null || data.isOnline is bool);
    }

    function isValidConfig(data) {
      return (!('geminiApiKeys' in data) || (data.geminiApiKeys is list)) &&
             (!('groqApiKey' in data) || (data.groqApiKey is string)) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    // Chat Rules
    match /chats/{chatId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidChat(request.resource.data);
      allow update: if isOwner(resource.data.userId) && 
                      isValidChat(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.userId);

      // Message Rules
      match /messages/{messageId} {
        allow read: if isChatOwner(chatId);
        allow create: if isChatOwner(chatId) && isValidMessage(request.resource.data);
        // Allow updates for streaming content
        allow update: if isChatOwner(chatId) && 
                        isValidMessage(request.resource.data) &&
                        request.resource.data.role == resource.data.role &&
                        request.resource.data.chatId == resource.data.chatId &&
                        request.resource.data.createdAt == resource.data.createdAt;
        allow delete: if isChatOwner(chatId);
      }
    }

    // Script Rules
    match /scripts/{scriptId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isAuthenticated() && isValidScript(request.resource.data);
      allow update: if isOwner(resource.data.userId) && 
                      isValidScript(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.userId);
    }

    // User Rules
    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    // Config Rules
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() && isValidConfig(request.resource.data);
    }

    match /error_logs/{logId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /moderation_reports/{reportId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    match /security_alerts/{alertId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
